rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function hasRole(roleName) {
      return request.auth != null && request.auth.token.role == roleName;
    }

    function isLoggeIn() {
      return request.auth != null;
    }
    
    // Safely check admin claim — avoids crash when custom claim is undefined
    function isAdmin() {
      return request.auth != null && (request.auth.token.get('admin', false) == true || request.auth.token.get('superAdmin', false) == true);
    }

    // Globally accessible if admin
    match /{document=**} {
      allow read, write: if isAdmin(); 
    }

    // Admin Users Directory (Tracking who is an admin)
    match /adminUsers/{uid} {
      allow read: if isAdmin(); // Only admins can see the list of admins
      allow write: if false; // Only Cloud Functions can write to this
    }


    // User profiles
    match /users/{userId} {
      allow read: if isLoggeIn();
      allow create: if isOwner(userId);
      // Owner can update any of their own fields.
      // Role changes from the admin panel go through Cloud Functions (admin SDK bypasses rules).
      allow update: if isOwner(userId);

      // Notifications subcollection — only the owner can read/write their notifications
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }

      // Connections subcollection
      match /connections/{connId} {
        allow read: if isLoggeIn();
        allow write: if isOwner(userId);
      }

      // Saved Posts subcollection — only the owner can read/write their bookmarks
      match /savedPosts/{postId} {
        allow read, write: if isOwner(userId);
      }
    }


    // Role requests
    match /roleChangeRequests/{requestId} {
      allow read: if isOwner(resource.data.userId);
      // Only allow creating a request for yourself, default to pending
      allow create: if isOwner(request.resource.data.userId) && request.resource.data.status == 'pending';
    }

    // Posts and their subcollections
    match /posts/{postId} {
      allow read: if isLoggeIn();
      // Require authorId to match uid, initialize likes and comments to 0
      allow create: if isOwner(request.resource.data.authorId) && 
                       request.resource.data.likesCount == 0 && 
                       request.resource.data.commentsCount == 0;
      // Only allow updates to content/mediaUrl, OR allow anyone to increment likes (handled securely via functions theoretically, but relaxed for demo)
      allow update: if isOwner(resource.data.authorId) || isLoggeIn(); 
      allow delete: if isOwner(resource.data.authorId);
      
      match /comments/{commentId} {
        allow read: if isLoggeIn();
        allow create: if isOwner(request.resource.data.authorId);
        allow update, delete: if isOwner(resource.data.authorId);
      }
      
      match /likes/{userId} {
        allow read: if isLoggeIn();
        allow write: if isOwner(userId);
      }
    }

    // Conversations / Chats
    match /chats/{chatId} {
      // Allowed if their ID is in the participants array
      allow read, update: if isLoggeIn() && request.auth.uid in resource.data.participants;
      allow create: if isLoggeIn() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        // Can only read/write if part of the parent chat
        allow read: if isLoggeIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isOwner(request.resource.data.senderId) && 
                      request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Connection Requests
    match /connectionRequests/{reqId} {
      allow read: if isLoggeIn() && (isOwner(resource.data.senderId) || isOwner(resource.data.targetId));
      allow create: if isOwner(request.resource.data.senderId) && request.resource.data.status == 'pending';
      // Only target can update (accept/reject via function, but rule protects direct access)
      allow update: if isOwner(resource.data.targetId);
      allow delete: if isOwner(resource.data.senderId) || isOwner(resource.data.targetId);
    }

    // Jobs
    match /jobs/{jobId} {
      allow read: if isLoggeIn();
      // Only recruiters can create/update jobs, and only their own
      allow create: if hasRole('Recruiter') && isOwner(request.resource.data.recruiterId);
      allow update, delete: if hasRole('Recruiter') && isOwner(resource.data.recruiterId);
      
      match /applications/{appId} {
        // Anyone can apply (create) for themselves
        allow create: if isOwner(request.resource.data.applicantId);
        // Only applicant and the job's recruiter can read
        allow read: if isOwner(resource.data.applicantId) || 
                       isOwner(get(/databases/$(database)/documents/jobs/$(jobId)).data.recruiterId);
      }
    }
    
    // Admin Logs (write handled by Cloud Functions / Admin SDK)
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}

