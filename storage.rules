rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    function isVideo() {
      return request.resource.contentType.matches('video/.*');
    }
    function isPDF() {
      return request.resource.contentType == 'application/pdf';
    }
    function sizeLt(mb) {
      return request.resource.size < mb * 1024 * 1024;
    }
    function isAdmin() {
      return request.auth != null && (request.auth.token.get('admin', false) == true || request.auth.token.get('superAdmin', false) == true);
    }

    // Admins can do anything
    match /{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // ── Avatars ──────────────────────────────────────────────
    // READ: public (anyone can view profile pictures, even unauthenticated)
    // WRITE: owner only, images ≤ 5MB
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if isOwner(userId) && isImage() && sizeLt(5);
    }

    // ── Post Media ───────────────────────────────────────────
    // READ: any signed-in user
    // WRITE: owner only, images or videos ≤ 20MB
    match /posts/{userId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && (isImage() || isVideo()) && sizeLt(20);
    }

    // ── Resumes ──────────────────────────────────────────────
    // READ: owner only (recruiters get access via Cloud Functions)
    // WRITE: owner only, PDF ≤ 10MB
    match /resumes/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isPDF() && sizeLt(10);
    }

    // ── Chat Media ───────────────────────────────────────────
    // READ: signed-in users (message access controlled by Firestore)
    // WRITE: signed-in users, images ≤ 10MB
    match /chats/{chatId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isImage() && sizeLt(10);
    }
  }
}
